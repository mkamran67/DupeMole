{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DupeMole",
  "version": "0.1.0",
  "identifier": "com.dupemole.app",
  "build": {
    "beforeDevCommand": "npm --prefix desktop run dev",
    "beforeBuildCommand": "npm --prefix desktop run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../desktop/out"
  },
  "app": {
    "windows": [
      {
        "title": "DupeMole",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
